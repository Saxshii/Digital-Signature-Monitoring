<!DOCTYPE html>
<html>

<head>
    <title>DSC Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5">

        <h1 class="text-center mb-4">
            DSC Monitoring Dashboard
        </h1>

        <div class="row mb-4">

            <div class="col-md-4">
                <div class="card text-center shadow">
                    <div class="card-body">
                        <h5>Total Employees</h5>
                        <h2>
                            <%= total %>
                        </h2>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card text-center shadow border-warning">
                    <div class="card-body">
                        <h5>Expiring Soon</h5>
                        <h2 class="text-warning">
                            <%= expiring %>
                        </h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow">

            <div class="card-header">
                Employee DSC Status
            </div>

            <div class="card-body">

                <table class="table table-bordered table-hover">

                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Expiry Date</th>
                            <th>Days Left</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% employees.forEach(emp=> { %>

                            <tr>

                                <td>
                                    <%= emp.name %>
                                </td>

                                <td>
                                    <%= emp.email %>
                                </td>

                                <td>
                                    <%= emp.expiryDate %>
                                </td>

                                <td>
                                    <%= emp.daysLeft %>
                                </td>

                                <td>

                                    <% if(emp.status==="Active" ){ %>

                                        <span class="badge bg-success">
                                            Active
                                        </span>

                                        <% } else if(emp.status==="Expiring Soon" ){ %>

                                            <span class="badge bg-warning text-dark">
                                                Expiring Soon
                                            </span>

                                            <% } else { %>

                                                <span class="badge bg-danger">
                                                    Expired
                                                </span>

                                                <% } %>

                                </td>

                            </tr>

                            <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</body>

</html>