<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>CWC DSC Portal</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #f8f9fa;
        }

        .section-title {
            color: #1f5d99;
            font-weight: 700;
        }

        .carousel-item img {
            height: 500px;
            object-fit: cover;
        }
    </style>

</head>

<body>

    <%- include("partials/navbar") %>

        <!-- CAROUSEL -->
        <div id="cwcCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item">
                    <img src="/images/1.jpg" class="d-block w-100">
                </div> 
                <div class="carousel-item active">
                    <img src="/images/4.png" class="d-block w-100">
                </div>
                <div class="carousel-item active">
                    <img src="/images/7.jpg" class="d-block w-100">
                </div>
                <div class="carousel-item">
                    <img src="/images/3.jpeg" class="d-block w-100">
                </div>
                <div class="carousel-item active">
                    <img src="/images/5.png" class="d-block w-100">
                </div>
                <div class="carousel-item active">
                    <img src="/images/6.png" class="d-block w-100">
                </div>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#cwcCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#cwcCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>

        </div>

        <!-- ABOUT -->

        <div class="container my-5">
            <div class="row align-items-center">
                <div class="col-md-7">

                    <h2 class="section-title mb-4"> About Central Warehousing Corporation</h2>
                    <p class="fs-5">
                        Central Warehousing Corporation (CWC) is a Government of India Public Sector Enterprise established in 1957. CWC provides scientific warehousing, logistics, supply chain, container freight stations, inland container
                        depots and integrated storage solutions across India.

                        The corporation plays a vital role insupporting agriculture, trade, industry and public distribution through its extensivenationwide warehousing network.
                    </p>
                </div>

                <div class="col-md-5 text-center">
                    <img src="/images/2.jpg" class="img-fluid rounded shadow">
                </div>

            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>