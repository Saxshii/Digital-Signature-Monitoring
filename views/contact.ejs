<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - CWC DSC Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <link rel="stylesheet" href="/css/footer.css">
    <style>
        body {
            background: #f8f9fa;
        }
        .section-title {
            color: #1f5d99;
            font-weight: 700;
        }
        .hero-banner {
            background: linear-gradient(rgba(31, 93, 153, 0.78), rgba(31, 93, 153, 0.78)),
                url('/images/7.jpg') center/cover no-repeat;
            color: white;
            padding: 80px 0;
        }
        .contact-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 4px 16px rgba(31, 93, 153, 0.1);
            transition: transform 0.2s;
        }
        .contact-card:hover {
            transform: translateY(-4px);
        }
        .contact-icon {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: #1f5d99;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.4rem;
            flex-shrink: 0;
        }
        .form-section {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        }
        .form-control:focus, .form-select:focus {
            border-color: #1f5d99;
            box-shadow: 0 0 0 0.2rem rgba(31, 93, 153, 0.15);
        }
        .btn-cwc {
            background: #1f5d99;
            color: white;
            border: none;
            padding: 10px 36px;
            border-radius: 8px;
            font-weight: 600;
            transition: background 0.2s;
        }
        .btn-cwc:hover {
            background: #174a7a;
            color: white;
        }
        .map-embed {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        }
        .section-divider {
            border: none;
            height: 3px;
            background: linear-gradient(to right, #1f5d99, transparent);
            width: 60px;
            margin-bottom: 1.5rem;
        }
        .alert-success-cwc {
            background: #e8f4e8;
            border: 1px solid #4caf50;
            color: #2e7d32;
            border-radius: 8px;
        }
    </style>
</head>

<body>
    <%- include("partials/navbar") %>

    <!-- HERO BANNER -->
    <div class="hero-banner text-center">
        <div class="container">
            <h1 class="fw-bold mb-3">Contact Us</h1>
            <p class="fs-5 mb-0">Reach out to the CWC Corporate Office, New Delhi</p>
        </div>
    </div>

    <!-- CONTACT INFO CARDS -->
    <div class="container my-5">
        <h2 class="section-title text-center mb-2">Get In Touch</h2>
        <hr class="section-divider mx-auto">
        <div class="row g-4 mt-2">

            <div class="col-md-4">
                <div class="card contact-card p-4 h-100">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="contact-icon"><i class="bi bi-geo-alt-fill"></i></div>
                        <div>
                            <h5 class="fw-bold mb-1">Corporate Office</h5>
                            <p class="text-muted mb-0">
                                Central Warehousing Corporation<br>
                                4/1, Siri Institutional Area,<br>
                                Hauz Khas, New Delhi – 110016
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card contact-card p-4 h-100">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="contact-icon"><i class="bi bi-telephone-fill"></i></div>
                        <div>
                            <h5 class="fw-bold mb-1">Phone</h5>
                            <p class="text-muted mb-0">
                                <!-- +91-11-26862921<br>
                                +91-11-26862922<br>
                                <span class="text-muted" style="font-size:0.85rem;">Mon – Fri, 9:00 AM – 5:30 PM</span> -->
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card contact-card p-4 h-100">
                    <div class="d-flex gap-3 align-items-start">
                        <div class="contact-icon"><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <h5 class="fw-bold mb-1">Email</h5>
                            <p class="text-muted mb-0">
                                <a href="mailto:info@cewacor.nic.in" class="text-decoration-none" style="color:#1f5d99;">info@cewacor.nic.in</a><br>
                                <a href="mailto:dsc-support@cwc.gov.in" class="text-decoration-none" style="color:#1f5d99;">dsc-support@cwc.gov.in</a><br>
                                <span style="font-size:0.85rem;">(for DSC portal queries)</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- CONTACT FORM + MAP -->
    <div class="container mb-5">
        <div class="row g-4">

            <!-- FORM -->
            <div class="col-md-6">
                <div class="form-section p-4 p-md-5 h-100">
                    <h4 class="section-title mb-2">Send a Query</h4>
                    <hr class="section-divider">

                    <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert-success-cwc p-3 mb-4">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        Your message has been sent successfully. We'll get back to you shortly.
                    </div>
                    <% } %>

                    <form action="/contact" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input type="text" name="name" class="form-control" placeholder="Enter your full name" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                            <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Department / Designation</label>
                            <input type="text" name="department" class="form-control" placeholder="e.g. IT Department, Accounts">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Query Type <span class="text-danger">*</span></label>
                            <select name="queryType" class="form-select" required>
                                <option value="" disabled selected>Select query type</option>
                                <option value="dsc">DSC Portal / Certificate Issue</option>
                                <option value="warehousing">Warehousing Services</option>
                                <option value="general">General Enquiry</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
                            <textarea name="message" class="form-control" rows="4" placeholder="Describe your query..." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-cwc w-100">
                            <i class="bi bi-send me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>

            
        </div>
    </div>

    <%- include("partials/footer") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>